# Django
SECRET_KEY=change-me-to-a-real-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.gov.in

# Database
DATABASE_URL=postgres://user:password@localhost:5432/digilocker

# DigiLocker Issuer Config
ISSUER_ID=in.gov.state.department
API_KEY=your-shared-api-key
BASE_STORAGE_PATH=/data/docs

# Operational Modes (STRICT | LOG_AND_SERVE)
INTEGRITY_MODE=STRICT
# Identity Validation (STRICT | LENIENT)
IDENTITY_VALIDATION_MODE=STRICT

# Limits
MAX_FILE_SIZE_MB=10
REQUEST_TIMEOUT_MS=5000
TIMESTAMP_SKEW_SECONDS=300
